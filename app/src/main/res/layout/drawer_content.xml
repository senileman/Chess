<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_custom"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="#1A1A1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="32dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- ── Piece Randomizer ───────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PIECE RANDOMIZER"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="14dp" />

        <!-- Base Starting Score -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Base Score per Side  (15 – 135)"
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:paddingBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#555555"
            app:hintTextColor="#888888">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBaseScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="39"
                android:textColor="#FFFFFF"
                android:hint="e.g. 39 (standard)" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Piece values: Pawn=1 · Knight/Bishop=3 · Rook=5 · Queen=9"
            android:textColor="#666666"
            android:textSize="11sp"
            android:paddingTop="4dp"
            android:paddingBottom="20dp" />

        <!-- Point Difference label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Point Difference"
                android:textColor="#DDDDDD"
                android:textSize="14sp" />

            <!-- Live readout: "+24 ⬜ White bonus" / "−24 ⬛ Black bonus" / "0  (even)" -->
            <TextView
                android:id="@+id/tvSliderValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0  (even)"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:minWidth="100dp"
                android:gravity="end" />

        </LinearLayout>

        <!--
            Slider range: −120 to +120
            Positive → white bonus  (white gets BSS + pd,   black stays at BSS)
            Negative → black bonus  (black gets BSS + |pd|, white stays at BSS)
        -->
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderPointDiff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="-120"
            android:valueTo="120"
            android:value="0"
            android:stepSize="1"
            app:thumbColor="#CCCCCC"
            app:trackColorActive="#CCCCCC"
            app:trackColorInactive="#444444"
            app:haloColor="@android:color/transparent" />

        <!-- Slider axis labels — left = white bonus, right = black bonus -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⬛ Black bonus"
                android:textColor="#666666"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="White bonus ⬜"
                android:textColor="#666666"
                android:textSize="11sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnRandomize"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Randomize &amp; Start"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="#444444" />

        <!-- ── Divider ─────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:background="#333333" />

        <!-- ── Timer ──────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TIMER"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:paddingBottom="14dp" />

        <!-- Timer on/off toggle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Timer"
                android:textColor="#DDDDDD"
                android:textSize="14sp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />

        </LinearLayout>

        <!-- Time format controls — only visible when timer is enabled -->
        <LinearLayout
            android:id="@+id/layoutTimerInputs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- White time format -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⬜  White"
                android:textColor="#DDDDDD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleWhiteTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/btnWhite60"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="60m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Very Long – 60 minutes" />

                <Button
                    android:id="@+id/btnWhite30"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="30m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Long – 30 minutes" />

                <Button
                    android:id="@+id/btnWhite15"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="15m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Medium – 15 minutes" />

                <Button
                    android:id="@+id/btnWhite5"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="5m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Short – 5 minutes" />

                <Button
                    android:id="@+id/btnWhite1"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="1m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Bullet – 1 minute" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="60m Very Long · 30m Long · 15m Medium · 5m Short · 1m Bullet"
                android:textColor="#555555"
                android:textSize="10sp"
                android:paddingTop="4dp"
                android:paddingBottom="16dp" />

            <!-- Black time format -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⬛  Black"
                android:textColor="#DDDDDD"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleBlackTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <Button
                    android:id="@+id/btnBlack60"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="60m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Very Long – 60 minutes" />

                <Button
                    android:id="@+id/btnBlack30"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="30m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Long – 30 minutes" />

                <Button
                    android:id="@+id/btnBlack15"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="15m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Medium – 15 minutes" />

                <Button
                    android:id="@+id/btnBlack5"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="5m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Short – 5 minutes" />

                <Button
                    android:id="@+id/btnBlack1"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="1m"
                    android:textSize="11sp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:contentDescription="Bullet – 1 minute" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecting a format resets that side's clock immediately."
                android:textColor="#555555"
                android:textSize="10sp"
                android:paddingTop="6dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
